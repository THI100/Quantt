{
  "name": "quantt-ui",
  "main": "electron/main.js",
  "productName": "Quantt",
  "description": "A trading algorithm for Crypto markets, automated and custom methods, utilizing CCXT for multi-plataform usage.",
  "author": "THI100 <thiagocas100@gmail.com>",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build_ft": "vite build",
    "build_electron": "electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "build": {
    "appId": "com.quantt.ui",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../quantt-engine/dist/QuanttEngine",
        "to": "backend-dist/main",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/qi.ico",
      "artifactName": "Quantt_Setup_${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/qi.icns",
      "artifactName": "Quantt_Mac_${version}.${ext}"
    }
  },
  "dependencies": {
    "axios": "^1.15.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
